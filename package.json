{
  "name": "hour-beeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "APP_VARIANT=development expo start --dev-client --clear",
    "start": "APP_VARIANT=development expo start --dev-client",
    "ios": "APP_VARIANT=development bun scripts/ios.ts",
    "build:dev:ios": "bun scripts/build.ts development ios",
    "build:stag:ios": "bun scripts/build.ts staging ios",
    "build:prod:ios": "bun scripts/build.ts production ios --auto-submit",
    "run:ios": "bun x eas-cli@latest build:run -e development-sim -p ios --latest",
    "prebuild": "APP_VARIANT=development expo prebuild",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fast": "oxlint",
    "format": "prettier --write .",
    "tests": "vitest run",
    "tests:watch": "vitest",
    "doctor": "bun x expo-doctor@latest",
    "doctor:fix": "bun x expo install --check",
    "add-device": "bun x eas-cli@latest device:create",
    "resign-after-new-device": "bun scripts/resign-staging.ts",
    "resign-after-new-device:non-interactive": "bun scripts/resign-staging.ts --non-interactive",
    "clean": "rimraf ios android",
    "eas": "bun x eas-cli@latest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "expo": "~55.0.15",
    "expo-constants": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-linking": "~55.0.13",
    "expo-notifications": "~55.0.19",
    "expo-router": "~55.0.12",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "jotai": "^2.19.0",
    "luxon": "^3.7.2",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "tailwind-merge": "^3.5.0",
    "uniwind": "^1.6.2"
  },
  "devDependencies": {
    "@expo/config-types": "^55.0.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/luxon": "^3.7.1",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "eas-build-cache-provider": "^18.5.0",
    "expo-build-disk-cache": "^0.7.4",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
