    "babel-plugin-module-resolver": "^5.0.3",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.21.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
