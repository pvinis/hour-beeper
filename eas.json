{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "development-sim": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "autoIncrement": true,
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "APP_VARIANT": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "APP_VARIANT": "production"
      }
    }
  }
}
