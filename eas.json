{
  "cli": {
    "version": ">= 18.11.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "development-sim": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "autoIncrement": true,
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "APP_VARIANT": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "pvinis@gmail.com",
        "appleTeamId": "CAG2W9M777",
        "bundleIdentifier": "com.pvinis.hourbeeper",
        "ascAppId": "6768447598",
        "appName": "Hour Bell - Hourly Chime",
        "language": "en-US"
      }
    }
  }
}
